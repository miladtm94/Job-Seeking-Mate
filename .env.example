APP_ENV=development
APP_NAME=job-seeking-mate-api
API_V1_PREFIX=/api/v1

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=jobmate
POSTGRES_USER=jobmate
POSTGRES_PASSWORD=jobmate
DATABASE_URL=postgresql+psycopg://jobmate:jobmate@db:5432/jobmate

REDIS_URL=redis://redis:6379/0

CORS_ORIGINS=http://localhost:5173

# Auth — change before deploying to any shared/hosted environment
JWT_SECRET_KEY=change-me-in-production
APP_USERNAME=admin
APP_PASSWORD=jobmate

# ──────────────────────────────────────────────────────────────
# AI Provider — set AI_PROVIDER to one of:
#   anthropic | openai | gemini | lmstudio | ollama
# ──────────────────────────────────────────────────────────────

# ── Option 1: Anthropic Claude (recommended) ──────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# ── Option 2: Google Gemini (free tier available) ─────────────
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# AI_MODEL=gemini-2.0-flash

# ── Option 3: OpenAI ──────────────────────────────────────────
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# AI_MODEL=gpt-4o

# ── Option 4: LM Studio (local, FREE, no API key needed) ──────
# 1. Download LM Studio from https://lmstudio.ai
# 2. Load any model (e.g. Llama 3.2, Mistral, Qwen, Phi-4)
# 3. Go to "Local Server" tab and click "Start Server"
# 4. Set the model ID exactly as shown in the LM Studio server panel
# AI_PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF

# ── Option 5: Ollama (local, FREE) ────────────────────────────
# 1. Install Ollama: https://ollama.ai
# 2. Run: ollama pull llama3.2 (or any other model)
# 3. Ollama starts automatically at localhost:11434
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# AI_MODEL=llama3.2

# Optional: use a cheaper/faster model just for job scoring
# AI_SCORE_MODEL=gemini-2.0-flash

# ── Job search providers ──────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# ── Application settings ──────────────────────────────────────
AUTO_APPLY_THRESHOLD=75
MAX_JOBS_PER_SEARCH=50
MATCH_REJECT_THRESHOLD=60
