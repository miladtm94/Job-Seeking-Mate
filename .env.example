APP_ENV=development
APP_NAME=job-seeking-mate-api
API_V1_PREFIX=/api/v1

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=jobmate
POSTGRES_USER=jobmate
POSTGRES_PASSWORD=jobmate
DATABASE_URL=postgresql+psycopg://jobmate:jobmate@db:5432/jobmate

REDIS_URL=redis://redis:6379/0

CORS_ORIGINS=http://localhost:5173

# AI provider (required for AI features)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Job search providers
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Application settings
AUTO_APPLY_THRESHOLD=75
MAX_JOBS_PER_SEARCH=50
MATCH_REJECT_THRESHOLD=60
